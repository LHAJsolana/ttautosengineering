# Use either Resend email delivery or a webhook for lead submissions.
RESEND_API_KEY=
LEAD_TO_EMAIL=contact@ttautosengineering.com
LEAD_FROM_EMAIL=TT AUTO'S Leads <leads@ttautosengineering.com>

# Optional alternative to Resend (CRM, automation platform, or private endpoint).
LEAD_WEBHOOK_URL=
LEAD_WEBHOOK_SECRET=

# Optional bot protection. Configure both values together.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
